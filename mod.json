{
	"geode": "5.7.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "enimeoww.layers-offset",
	"name": "Layers Offset",
	"version": "v1.1.0",
	"developer": "enimeoww",
	"description": "Easily reoffset your layers",
	"dependencies": {
		"geode.node-ids": ">=v1.23.3"
	},
	"links": {
		"source": "https://github.com/zL4mpY/layers-offset-mod"
	},
	"resources": {
		"spritesheets": {
			"ReoffsetButton": [
				"resources/*.png"
			]
		}
	},
	"settings": {
		"show-warning": {
			"type": "bool",
			"name": "Show Warning",
			"description": "Show the confirmation popup before reoffsetting the layers.",
			"default": true
		},
		"reoffset-layers-keybind": {
			"type": "keybind",
			"name": "Reoffset Layers",
			"category": "editor",
			"default": []
		}
	},
	"tags": ["editor", "offline", "enhancement"]
}
